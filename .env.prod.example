# zeynepkomur.com Production Environment
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod to git.

# Database
DATABASE_URL=file:./data/zeyneple.db

# Auth
AUTH_SECRET=  # Generate: openssl rand -base64 32
NEXTAUTH_SECRET=  # Same as AUTH_SECRET
NEXTAUTH_URL=https://zeynepkomur.com
AUTH_TRUST_HOST=true

# Admin
ADMIN_EMAIL=admin@zeynepkomur.com
ADMIN_PASSWORD=  # Strong password

# Email (Resend)
RESEND_API_KEY=  # From https://resend.com/api-keys
NOTIFICATION_EMAIL=  # Where form submissions go
EMAIL_FROM=noreply@zeynepkomur.com

# Mailcraft (Email Builder)
MAILCRAFT_API_KEY=  # From https://mailcraft.contentor.app dashboard
MAILCRAFT_ORIGIN=https://mailcraft.contentor.app

# Domain (used by Caddyfile)
DOMAIN=zeynepkomur.com
